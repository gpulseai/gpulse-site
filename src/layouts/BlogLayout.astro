---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  readingTime?: string;
  tags?: string[];
  ogImage?: string;
}

const {
  title,
  description,
  date,
  author = 'Karthik Kirubakaran',
  readingTime = '3 min read',
  tags = [],
  ogImage = '/og-image.png',
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(canonicalURL.toString());
---

<BaseLayout
  title={`${title} — gpulse blog`}
  description={description}
  ogImage={ogImage}
>
  <!-- Article-specific meta tags -->
  <Fragment slot="default">
    <article class="relative mx-auto max-w-3xl px-4 pt-32 pb-24 sm:px-6 lg:px-8">
      <!-- Back to blog -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-muted transition-colors hover:text-cyan mb-8"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to blog
      </a>

      <!-- Header -->
      <header class="mb-10">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {tags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-cyan/10 border border-cyan/20 px-3 py-0.5 text-xs font-medium text-cyan">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl leading-[1.15]">
          {title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-muted">
          <span>{author}</span>
          <span class="text-border" aria-hidden="true">|</span>
          <time datetime={date}>{formattedDate}</time>
          <span class="text-border" aria-hidden="true">|</span>
          <span>{readingTime}</span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert prose-cyan max-w-none
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:text-muted [&_ul]:space-y-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4
        [&_ol]:text-muted [&_ol]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4
        [&_a]:text-cyan [&_a]:underline [&_a]:underline-offset-4 [&_a]:transition-colors hover:[&_a]:text-cyan-dark
        [&_code]:font-mono [&_code]:text-sm [&_code]:text-cyan [&_code]:bg-surface [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
        [&_pre]:rounded-xl [&_pre]:border [&_pre]:border-border [&_pre]:bg-[#0d0d0d] [&_pre]:px-5 [&_pre]:py-4 [&_pre]:overflow-x-auto [&_pre]:mb-4
        [&_blockquote]:border-l-2 [&_blockquote]:border-cyan/30 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-muted/80
        [&_strong]:text-white [&_strong]:font-semibold
        [&_table]:w-full [&_table]:text-sm [&_table]:border-collapse
        [&_thead]:border-b [&_thead]:border-border
        [&_th]:px-4 [&_th]:py-3 [&_th]:text-left [&_th]:font-semibold
        [&_td]:px-4 [&_td]:py-3 [&_td]:text-muted
        [&_tr]:border-b [&_tr]:border-border/30
      ">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-12 rounded-xl border border-cyan/20 bg-cyan/5 p-6 text-center">
        <p class="text-lg font-semibold mb-2">Try gpulse free</p>
        <pre class="inline-block rounded-lg border border-border bg-[#0d0d0d] px-5 py-3 font-mono text-sm text-muted"><code>brew tap gpulseai/gpulse && brew install gpulse</code></pre>
        <p class="mt-3 text-sm text-muted">
          <a href="/download" class="text-cyan underline underline-offset-4 hover:text-cyan-dark transition-colors">Download options</a>
          <span class="mx-2 text-border" aria-hidden="true">|</span>
          <a href="/docs/getting-started" class="text-cyan underline underline-offset-4 hover:text-cyan-dark transition-colors">Getting started guide</a>
        </p>
      </div>

      <!-- Share -->
      <div class="mt-10 flex items-center gap-4 border-t border-border pt-8">
        <span class="text-sm font-semibold text-muted">Share:</span>
        <a
          href={`https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-surface px-3 py-2 text-xs font-medium text-muted transition-colors hover:text-white hover:border-border-hover"
          aria-label="Share on X (Twitter)"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          X / Twitter
        </a>
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-surface px-3 py-2 text-xs font-medium text-muted transition-colors hover:text-white hover:border-border-hover"
          aria-label="Share on LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          LinkedIn
        </a>
        <a
          href={`https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-border bg-surface px-3 py-2 text-xs font-medium text-muted transition-colors hover:text-white hover:border-border-hover"
          aria-label="Share on Reddit"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z" />
          </svg>
          Reddit
        </a>
      </div>
    </article>
  </Fragment>
</BaseLayout>
