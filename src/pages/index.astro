---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import Screenshot from '../components/Screenshot.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Badge } from '../components/ui/Badge';
import { Button } from '../components/ui/Button';
import { Card } from '../components/ui/Card';
---

<BaseLayout>
  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center px-4 pt-24 pb-16"
    aria-labelledby="hero-heading"
  >
    <!-- Subtle radial gradient background -->
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 h-[800px] w-[800px] rounded-full bg-cyan/[0.03] blur-[120px]"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center">
      <!-- Eyebrow badge -->
      <Badge variant="cyan" client:load>
        v2.0.0 — Now with OOM Prediction
      </Badge>

      <!-- Headline -->
      <h1
        id="hero-heading"
        class="text-5xl md:text-7xl font-extrabold text-center mt-8 tracking-tight leading-[1.1]"
      >
        Never lose a training run<br />
        <span class="text-cyan">to OOM.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-muted text-center mt-6 max-w-2xl leading-relaxed">
        Real-time GPU monitoring with predictive leak detection.
        Apple Silicon, NVIDIA, AMD, Intel — one tool, every GPU.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <Button variant="primary" size="lg" href="#download" client:load>
          Download Free
        </Button>
        <Button variant="secondary" size="lg" href="/docs" client:load>
          View Docs
        </Button>
      </div>

      <!-- Terminal mockup -->
      <Terminal
        title="Install gpulse"
        command="brew install kkirubakaran/gpulse/gpulse"
        class="mt-16 max-w-2xl w-full"
      />

      <!-- Hero screenshot -->
      <Screenshot
        src="/screenshots/grid-4gpu.png"
        alt="gpulse dashboard monitoring 4 NVIDIA GPUs in grid view, showing real-time memory usage, utilization percentages, and process lists"
        caption="Grid view — 4x NVIDIA GPUs with real-time memory, utilization, and process monitoring"
        class="mt-12"
      />
    </div>
  </section>

  <!-- ─── Features Section ─── -->
  <section id="features" class="py-24 md:py-32" aria-labelledby="features-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="FEATURES"
        title="Everything you need to monitor GPUs"
        subtitle="From memory leaks to thermal throttling, gpulse watches it all."
      />

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Feature 1: Beautiful TUI Dashboard -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Beautiful TUI Dashboard</h3>
          <p class="text-muted leading-relaxed">
            btop-quality GPU monitoring. Memory, utilization, temperature, power, processes — all in one glance. 15 themes included.
          </p>
        </Card>

        <!-- Feature 2: OOM Prediction -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">OOM Prediction</h3>
          <p class="text-muted leading-relaxed">
            Detects memory leaks before they crash your training run. Linear trend analysis, spike detection, and pattern fingerprinting with real-time ETA to OOM.
          </p>
        </Card>

        <!-- Feature 3: Every GPU, One Tool -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Every GPU, One Tool</h3>
          <p class="text-muted leading-relaxed">
            Apple Silicon, NVIDIA, AMD, Intel. Universal monitoring with vendor-specific metrics. Local today, fleet monitoring coming soon.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── Screenshot Showcase Section ─── -->
  <section class="py-24 md:py-32 bg-surface" aria-labelledby="views-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="VIEW MODES"
        title="7 powerful ways to see your GPUs"
      />

      <div class="mt-16 grid grid-cols-1 gap-10 md:grid-cols-2">
        <Screenshot
          src="/screenshots/grid-4gpu.png"
          alt="gpulse grid view showing 4 GPUs with memory and utilization metrics"
          caption="Grid View — See all GPUs at a glance"
          glow={false}
        />
        <Screenshot
          src="/screenshots/predict-leak-detected.png"
          alt="gpulse predict mode showing OOM detection with linear trend analysis"
          caption="Predict Mode — OOM detection with real-time analysis"
          glow={false}
        />
        <Screenshot
          src="/screenshots/detail-gpu0-critical.png"
          alt="gpulse detail view showing deep dive into a single GPU with all metrics"
          caption="Detail View — Deep dive into a single GPU"
          glow={false}
        />
        <Screenshot
          src="/screenshots/compare-4gpu.png"
          alt="gpulse compare view showing side-by-side GPU comparison"
          caption="Compare View — Side-by-side GPU comparison"
          glow={false}
        />
      </div>
    </div>
  </section>

  <!-- ─── How It Works Section ─── -->
  <section class="py-24 md:py-32" aria-labelledby="get-started-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="GET STARTED"
        title="Monitor your GPUs in 30 seconds"
      />

      <div class="mt-16 grid grid-cols-1 gap-12 md:grid-cols-3">
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center">
          <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-cyan text-cyan font-bold font-mono text-lg mb-6">
            1
          </div>
          <h3 class="text-xl font-bold mb-4">Install</h3>
          <Terminal
            title="Terminal"
            command="brew install kkirubakaran/gpulse/gpulse"
            class="w-full"
          />
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center">
          <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-cyan text-cyan font-bold font-mono text-lg mb-6">
            2
          </div>
          <h3 class="text-xl font-bold mb-4">Launch</h3>
          <Terminal
            title="Terminal"
            command="gpulse dashboard"
            class="w-full"
          />
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center">
          <div class="flex items-center justify-center w-12 h-12 rounded-full border-2 border-cyan text-cyan font-bold font-mono text-lg mb-6">
            3
          </div>
          <h3 class="text-xl font-bold mb-4">Monitor</h3>
          <div class="w-full rounded-xl border border-border bg-surface p-6">
            <p class="text-muted text-sm leading-relaxed">
              Navigate views with keyboard shortcuts. Press <kbd class="inline-block rounded border border-border bg-dark px-1.5 py-0.5 font-mono text-xs text-cyan">?</kbd> for help.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pricing Section ─── -->
  <section id="pricing" class="py-24 md:py-32 bg-surface" aria-labelledby="pricing-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="PRICING"
        title="Free for individuals. Pro for teams."
        subtitle="No credit card required. Download and start monitoring in seconds."
      />

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Free Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <h3 class="text-xl font-bold">Free</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$0</span>
              <span class="text-muted text-sm">forever</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Local GPU monitoring
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                All vendors (NVIDIA, Apple, AMD, Intel)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                15 color themes
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                7 view modes
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                OOM prediction & leak detection
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Prometheus endpoint
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="#download" className="w-full" client:load>
                Download Now
              </Button>
            </div>
          </div>
        </Card>

        <!-- Pro Tier -->
        <Card highlighted={true} client:load>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-3">
              <h3 class="text-xl font-bold">Pro</h3>
              <Badge variant="cyan" client:load>Coming Soon</Badge>
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$29</span>
              <span class="text-muted text-sm">/month</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Free
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Fleet monitoring (SSH, up to 20 machines)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Email, Slack & Discord alerts
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Web dashboard
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Multi-machine support
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Priority support
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="#waitlist" className="w-full" client:load>
                Join Waitlist
              </Button>
            </div>
          </div>
        </Card>

        <!-- Enterprise Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <h3 class="text-xl font-bold">Enterprise</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">Custom</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Pro
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Cloud API integration (AWS/Azure/GCP)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Agent-based fleet monitoring
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                RBAC & SSO
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                GPU scheduling & orchestration
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Audit logs & SLA
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="secondary" size="lg" href="mailto:info@gpulse.ai" className="w-full" client:load>
                Contact Us
              </Button>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── FAQ Section ─── -->
  <section class="py-24 md:py-32" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="FAQ"
        title="Frequently asked questions"
      />

      <div class="mt-16 space-y-4">
        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            What GPUs are supported?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            gpulse supports NVIDIA (via NVML), Apple Silicon (via Metal/IOKit), AMD (via ROCm), and Intel (via Level Zero). All major GPU vendors are supported out of the box.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            Does gpulse work on Linux?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            gpulse currently supports macOS (both Apple Silicon and Intel). Linux support is coming soon in a future release.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            How does OOM prediction work?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            gpulse uses three algorithms — linear trend analysis, spike detection, and composite scoring — to analyze memory growth patterns in real-time. When a leak is detected, it calculates the estimated time to out-of-memory and alerts you.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            What data does gpulse collect?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            None. gpulse monitors your local GPU hardware and does not send any data anywhere. There is no telemetry, no analytics, and no phone-home. Your data stays on your machine.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            Is gpulse open source?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            The free tier is free to use but the source code is not publicly available. gpulse is distributed as a compiled binary.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            How do I report bugs or request features?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
