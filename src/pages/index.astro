---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import Screenshot from '../components/Screenshot.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Badge } from '../components/ui/Badge';
import { Button } from '../components/ui/Button';
import { Card } from '../components/ui/Card';
---

<BaseLayout>
  <!-- AEO: Structured summary for AI engines -->
  <div class="sr-only" aria-hidden="false">
    <p>gpulse is a real-time GPU monitoring tool for the terminal. It supports NVIDIA (via NVML), AMD (via ROCm), Intel (via Level Zero), and Apple Silicon (via Metal/IOKit) GPUs. Key features include predictive OOM (out-of-memory) detection using linear regression and spike analysis, 7 dashboard view modes (Grid, Detail, List, Predict, Compare, Topology, Fleet), 15 color themes, per-process GPU attribution, Prometheus metrics export, and fleet monitoring via SSH. gpulse is free for local monitoring. Install with: brew tap gpulseai/gpulse &amp;&amp; brew install gpulse. Available at https://gpulse.ai.</p>
  </div>

  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center px-4 pt-28 pb-20"
    aria-labelledby="hero-heading"
  >
    <!-- Subtle radial gradient background -->
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 h-[800px] w-[800px] rounded-full bg-cyan/[0.04] blur-[120px]"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center">
      <!-- Eyebrow badge -->
      <Badge variant="cyan" client:load>
        v2.2.0 — OOM Prediction is here
      </Badge>

      <!-- Headline -->
      <h1
        id="hero-heading"
        class="text-5xl md:text-7xl font-extrabold text-center mt-8 tracking-tight leading-[1.1]"
      >
        Never lose a training run<br />
        <span class="text-cyan text-glow">to OOM.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-muted text-center mt-6 max-w-2xl leading-relaxed">
        Real-time GPU monitoring with predictive memory leak detection. Supports Apple&nbsp;Silicon, NVIDIA, AMD, and Intel&nbsp;— all from a single terminal command.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <Button variant="primary" size="lg" href="#download" client:load>
          Download Free
        </Button>
        <Button variant="secondary" size="lg" href="#features" client:load>
          See Features
        </Button>
      </div>

      <!-- Terminal mockup -->
      <Terminal
        title="Install gpulse"
        command="brew tap gpulseai/gpulse && brew install gpulse"
        class="mt-14 max-w-2xl w-full glow-cyan"
      />

      <!-- Hero screenshot -->
      <Screenshot
        src="/screenshots/grid-8gpu.png"
        alt="gpulse dashboard monitoring 8 NVIDIA GPUs in grid view with Monokai theme, showing real-time VRAM usage, GPU utilization, temperature, power draw, OOM leak alert, and per-process attribution"
        caption="Grid view — 8 NVIDIA GPUs with real-time monitoring and OOM leak detection alert"
        class="mt-10"
      />
    </div>
  </section>

  <!-- ─── Features Section ─── -->
  <section id="features" class="py-24 md:py-32" aria-labelledby="features-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeader
          eyebrow="FEATURES"
          title="Everything you need to monitor GPUs"
          subtitle="Memory leaks, thermal throttling, OOM crashes — gpulse detects problems before they cost you hours of compute."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3 stagger-children fade-in-up">
        <!-- Feature 1: Beautiful TUI Dashboard -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Beautiful TUI Dashboard</h3>
          <p class="text-muted leading-relaxed">
            A btop-quality terminal interface with 7 purpose-built views, Monokai default theme, and vim-style navigation. See memory, utilization, temperature, power draw, and per-process attribution at a glance. Ships with 15 themes. Customize everything with <code class="font-mono text-sm text-cyan bg-surface px-1.5 py-0.5 rounded">gpulse config</code>.
          </p>
        </Card>

        <!-- Feature 2: OOM Prediction -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Predictive OOM Detection</h3>
          <p class="text-muted leading-relaxed">
            Three algorithms — linear trend analysis, spike detection, and composite scoring — provide real-time risk scoring for every GPU. View results in the dedicated Predict view with per-GPU risk levels, growth rates, and estimated time-to-OOM before your training run crashes.
          </p>
        </Card>

        <!-- Feature 3: Every GPU, One Tool -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Every GPU, One Tool</h3>
          <p class="text-muted leading-relaxed">
            Supports Apple Silicon (Metal), NVIDIA (NVML), AMD (ROCm), and Intel (Level Zero). One binary, universal vendor coverage. Fleet monitoring for multi-machine setups coming soon.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── Scale Section ─── -->
  <section class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="scale-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeader
          eyebrow="SCALE"
          title="From laptop to fleet"
          subtitle="Start with local monitoring. Scale to 20 machines with Pro. Go unlimited with Enterprise cloud integration."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3 stagger-children fade-in-up">
        <!-- Local (Free) -->
        <div class="rounded-2xl border border-border bg-dark/80 p-8 hover:border-cyan/30 transition-all duration-300">
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-7 h-7 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <h3 class="text-xl font-bold">Local</h3>
            <span class="text-xs text-muted font-mono">FREE</span>
          </div>
          <p class="text-lg text-muted mb-4">Monitor GPUs on your machine</p>
          <p class="text-sm text-muted/70 leading-relaxed">
            Install and run. No account needed. Full OOM prediction, 15 themes, 7 view modes, and Prometheus endpoint included.
          </p>
        </div>

        <!-- Fleet (Pro) -->
        <div class="rounded-2xl border border-yellow/20 bg-dark/80 p-8 hover:border-yellow/40 transition-all duration-300 relative">
          <div class="absolute top-4 right-4">
            <Badge variant="yellow" client:load>PRO</Badge>
          </div>
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-yellow/10 mb-6">
            <svg class="w-7 h-7 text-yellow" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <h3 class="text-xl font-bold">Fleet</h3>
            <span class="text-xs text-yellow font-mono">$29/mo</span>
          </div>
          <p class="text-lg text-muted mb-4">Monitor up to 20 machines via SSH</p>
          <p class="text-sm text-muted/70 leading-relaxed">
            SSH into cloud VMs (AWS, Azure, GCP) or on-prem servers. Bastion/jump host support. Email, Slack, and Discord alerts. Advanced hardware metrics.
          </p>
        </div>

        <!-- Cloud-Scale (Enterprise) -->
        <div class="rounded-2xl border border-purple/20 bg-dark/80 p-8 hover:border-purple/40 transition-all duration-300 relative">
          <div class="absolute top-4 right-4">
            <Badge variant="purple" client:load>ENT</Badge>
          </div>
          <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-purple/10 mb-6">
            <svg class="w-7 h-7 text-purple" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <h3 class="text-xl font-bold">Cloud-Scale</h3>
            <span class="text-xs text-purple font-mono">CUSTOM</span>
          </div>
          <p class="text-lg text-muted mb-4">Auto-discover GPU instances across clouds</p>
          <p class="text-sm text-muted/70 leading-relaxed">
            Cloud API integration for AWS, Azure, and GCP. K8s DaemonSet deployment. Agent-based push for unlimited machines. RBAC, SSO, and audit logs.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <Button variant="secondary" size="lg" href="/pricing" client:load>
          Compare all features
        </Button>
      </div>
    </div>
  </section>

  <!-- ─── Who Uses gpulse Section ─── -->
  <section class="py-24 md:py-32" aria-labelledby="personas-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeader
          eyebrow="WHO USES GPULSE"
          title="Built for everyone who works with GPUs"
          subtitle="From solo researchers to platform teams managing hundreds of GPUs."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 stagger-children fade-in-up">
        <!-- ML Engineers -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">ML Engineers</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Stop losing training runs to OOM crashes. Predict memory exhaustion hours before it happens.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Predict mode, Detail view, Alerts
          </p>
        </Card>

        <!-- Data Scientists -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Data Scientists</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Know if your GPU is actually being used — or if you forgot <code class="text-cyan/70 text-xs">.to('cuda')</code> again.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Grid view, Process table, Framework detection
          </p>
        </Card>

        <!-- MLOps / Platform Teams -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">MLOps / Platform Teams</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Fleet-wide GPU visibility across your cluster. Know who's using what, and where capacity is wasted.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Grid view, Prometheus endpoint, Compare mode
          </p>
        </Card>

        <!-- Apple Silicon Users -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Mac Studio / Apple Silicon Users</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            First-class unified memory monitoring. See GPU share, memory pressure, and swap — no other tool does this.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Detail view, Memory pressure, Predict mode
          </p>
        </Card>

        <!-- SREs / DevOps -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">SREs / DevOps</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Thermal alerts before your GPUs throttle. Detect hardware failures before they cascade into incidents.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Prometheus endpoint, Compare mode, Alerts
          </p>
        </Card>

        <!-- Game Developers -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 01-.657.643 48.491 48.491 0 01-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 01-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 00-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 01-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 00.657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 01-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 005.427-.63 48.05 48.05 0 00.582-4.717.532.532 0 00-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 00.657-.663 48.422 48.422 0 00-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 01-.61-.58v0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Game Developers</h3>
          <p class="text-muted text-sm leading-relaxed mb-4">
            Profile VRAM budgets and thermal throttling during development. Cross-vendor, always-on, zero setup.
          </p>
          <p class="text-xs text-muted/60">
            <span class="text-cyan/70 font-mono">Uses:</span> Detail view, Grid view, Thermal monitoring
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── Screenshot Showcase Section ─── -->
  <section class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="views-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeader
          eyebrow="VIEW MODES"
          title="Seven ways to see your GPUs"
          subtitle="Switch between views with a single keystroke. Each mode is purpose-built for a different monitoring task."
        />
      </div>

      <div class="mt-16 grid grid-cols-1 gap-10 md:grid-cols-2 stagger-children fade-in-up">
        <Screenshot
          src="/screenshots/grid-8gpu.png"
          alt="gpulse Grid view with 8 NVIDIA GPUs showing VRAM usage bars, GPU utilization, temperature, power draw, OOM alert, and per-process attribution"
          caption="Grid View — 8 GPUs at a glance with OOM leak alert"
          glow={false}
        />
        <Screenshot
          src="/screenshots/detail-gpu4-critical.png"
          alt="gpulse Detail view showing GPU 4 NVIDIA RTX 4090 in critical state with extended metrics, process table, and memory history"
          caption="Detail View — Deep metrics for a single GPU"
          glow={false}
        />
        <Screenshot
