          ></textarea>
        </div>

        <div>
          <label for="feedback-email" class="block text-sm font-semibold text-muted mb-2">
            Email <span class="text-muted/50">(optional — for follow-up)</span>
          </label>
          <input
            type="email"
            id="feedback-email"
            name="email"
            placeholder="you@company.com"
            autocomplete="email"
            class="w-full rounded-xl border border-border bg-dark px-4 py-3 text-white placeholder:text-muted/50 focus:border-cyan focus:ring-1 focus:ring-cyan focus:outline-none transition-colors"
          />
        </div>

        <button type="submit" class="w-full rounded-xl bg-cyan px-6 py-3 font-semibold text-dark transition-all hover:bg-cyan-dark hover:scale-[1.02] active:scale-[0.98]">
          Submit Feedback
        </button>

        <div id="feedback-msg" class="text-sm hidden" aria-live="polite"></div>
      </form>

      <p class="text-center text-muted/50 text-xs mt-6">
        You can also reach us on <a href="https://discord.gg/nnU28awf" class="text-cyan/70 hover:text-cyan transition-colors" target="_blank" rel="noopener noreferrer">Discord</a> or via email at <a href="mailto:info@gpulse.ai" class="text-cyan/70 hover:text-cyan transition-colors">info@gpulse.ai</a>.
      </p>
    </div>
  </section>

  <!-- ─── Final CTA Section ─── -->
  <section id="download" class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="cta-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-4xl md:text-5xl font-bold tracking-tight">
        Stop guessing. Start monitoring.
      </h2>
      <p class="text-lg text-muted mt-4 max-w-xl mx-auto">
        One command to install. Zero configuration. Free forever for local monitoring.
      </p>

      <Terminal
        title="Install gpulse"
        command="brew tap gpulseai/gpulse && brew install gpulse"
        class="mt-10 max-w-2xl mx-auto"
      />

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" size="lg" href="/download" client:load>
          Download Free
        </Button>
        <Button variant="secondary" size="lg" href="#feedback" client:load>
          Send Feedback
        </Button>
      </div>
    </div>
  </section>

  <script>
    // ── Form Endpoints ──
    // Replace with your Cloudflare Worker or Formspree endpoint when ready.
    // Formspree example: 'https://formspree.io/f/YOUR_FORM_ID'
    // Worker example: 'https://gpulse-api.your-subdomain.workers.dev/api/waitlist'
    const WAITLIST_ENDPOINT = 'https://formspree.io/f/mdawqlow';
    const FEEDBACK_ENDPOINT = 'https://formspree.io/f/xqeyrdkw';

    function isValidEmail(email: string): boolean {
      return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email);
    }

    function showMsg(el: HTMLElement, message: string, type: 'success' | 'error') {
      el.textContent = message;
      el.className = `mt-4 text-sm ${type === 'success' ? 'text-green' : 'text-red'}`;
      if (type === 'success') {
        setTimeout(() => { el.className = 'mt-4 text-sm hidden'; }, 8000);
      }
    }

    // Waitlist form
    const wForm = document.getElementById('waitlist-form') as HTMLFormElement | null;
    const wMsg = document.getElementById('waitlist-msg');
    if (wForm && wMsg) {
      wForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const input = document.getElementById('waitlist-email') as HTMLInputElement;
        const email = input.value.trim();

        if (!email || !isValidEmail(email)) {
          showMsg(wMsg, 'Please enter a valid email address.', 'error');
          input.focus();
          return;
        }

        const btn = wForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const orig = btn.textContent || '';
        btn.textContent = 'Submitting\u2026';
        btn.disabled = true;

        try {
          if (WAITLIST_ENDPOINT) {
            await fetch(WAITLIST_ENDPOINT, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });
          } else {
            await new Promise(r => setTimeout(r, 600));
          }
          showMsg(wMsg, "You\u2019re on the list! We\u2019ll notify you when Pro launches.", 'success');
          input.value = '';
        } catch {
          showMsg(wMsg, 'Something went wrong. Please email info@gpulse.ai instead.', 'error');
        } finally {
          btn.textContent = orig;
          btn.disabled = false;
        }
      });
    }

    // Feedback form
    const fForm = document.getElementById('feedback-form') as HTMLFormElement | null;
    const fMsg = document.getElementById('feedback-msg');
    if (fForm && fMsg) {
      fForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const typeRadio = fForm.querySelector('input[name="feedback-type"]:checked') as HTMLInputElement | null;
        const descEl = document.getElementById('feedback-description') as HTMLTextAreaElement;
        const emailEl = document.getElementById('feedback-email') as HTMLInputElement;

        if (!typeRadio) {
          showMsg(fMsg, 'Please select Bug Report or Feature Request.', 'error');
          return;
        }

        const description = descEl.value.trim();
        if (!description || description.length < 10) {
          showMsg(fMsg, 'Please provide a description (at least 10 characters).', 'error');
          descEl.focus();
          return;
        }

        const email = emailEl.value.trim();
        if (email && !isValidEmail(email)) {
          showMsg(fMsg, 'Please enter a valid email address.', 'error');
          emailEl.focus();
          return;
        }

        const btn = fForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        const orig = btn.textContent || '';
        btn.textContent = 'Submitting\u2026';
        btn.disabled = true;

        try {
          if (FEEDBACK_ENDPOINT) {
            await fetch(FEEDBACK_ENDPOINT, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                type: typeRadio.value,
                description,
                email: email || undefined,
              }),
            });
          } else {
            await new Promise(r => setTimeout(r, 600));
          }
          const label = typeRadio.value === 'bug' ? 'Bug report' : 'Feature request';
          showMsg(fMsg, `${label} submitted. Thank you!`, 'success');
          fForm.reset();
        } catch {
          showMsg(fMsg, 'Something went wrong. Please email info@gpulse.ai instead.', 'error');
        } finally {
          btn.textContent = orig;
          btn.disabled = false;
        }
      });
    }
  </script>

</BaseLayout>
