---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import Screenshot from '../components/Screenshot.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Badge } from '../components/ui/Badge';
import { Button } from '../components/ui/Button';
import { Card } from '../components/ui/Card';
---

<BaseLayout>
  <!-- Hero Section -->
  <section
    class="relative min-h-screen flex flex-col items-center justify-center px-4 pt-28 pb-20"
    aria-labelledby="hero-heading"
  >
    <!-- Subtle radial gradient background -->
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 h-[800px] w-[800px] rounded-full bg-cyan/[0.04] blur-[120px]"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center">
      <!-- Eyebrow badge -->
      <Badge variant="cyan" client:load>
        v2.0.0 — OOM Prediction is here
      </Badge>

      <!-- Headline -->
      <h1
        id="hero-heading"
        class="text-5xl md:text-7xl font-extrabold text-center mt-8 tracking-tight leading-[1.1]"
      >
        Never lose a training run<br />
        <span class="text-cyan">to OOM.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-muted text-center mt-6 max-w-2xl leading-relaxed">
        Real-time GPU monitoring with predictive memory leak detection. Supports Apple&nbsp;Silicon, NVIDIA, AMD, and Intel&nbsp;— all from a single terminal command.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <Button variant="primary" size="lg" href="#download" client:load>
          Download Free
        </Button>
        <Button variant="secondary" size="lg" href="#features" client:load>
          See Features
        </Button>
      </div>

      <!-- Terminal mockup -->
      <Terminal
        title="Install gpulse"
        command="brew install kkirubakaran/gpulse/gpulse"
        class="mt-14 max-w-2xl w-full"
      />

      <!-- Hero screenshot -->
      <Screenshot
        src="/screenshots/grid-4gpu.png"
        alt="gpulse dashboard monitoring 4 NVIDIA GPUs in grid view with Monokai theme, showing real-time VRAM usage, GPU utilization, temperature, power draw, and per-process attribution"
        caption="Grid view — 4 NVIDIA GPUs with real-time memory, utilization, temperature, and process monitoring"
        class="mt-10"
      />
    </div>
  </section>

  <!-- ─── Features Section ─── -->
  <section id="features" class="py-24 md:py-32" aria-labelledby="features-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="FEATURES"
        title="Everything you need to monitor GPUs"
        subtitle="Memory leaks, thermal throttling, OOM crashes — gpulse detects problems before they cost you hours of compute."
      />

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Feature 1: Beautiful TUI Dashboard -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Beautiful TUI Dashboard</h3>
          <p class="text-muted leading-relaxed">
            A btop-quality terminal interface for GPU monitoring. See memory, utilization, temperature, power draw, and per-process attribution at a glance. Ships with 15 built-in themes.
          </p>
        </Card>

        <!-- Feature 2: OOM Prediction -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Predictive OOM Detection</h3>
          <p class="text-muted leading-relaxed">
            Three detection algorithms — linear trend analysis, spike detection, and composite scoring — monitor memory growth in real time. Get an estimated time-to-OOM before your training run crashes.
          </p>
        </Card>

        <!-- Feature 3: Every GPU, One Tool -->
        <Card client:load>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan/10 mb-6">
            <svg class="w-6 h-6 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Every GPU, One Tool</h3>
          <p class="text-muted leading-relaxed">
            Supports Apple Silicon (Metal), NVIDIA (NVML), AMD (ROCm), and Intel (Level Zero). One binary, universal vendor coverage. Fleet monitoring for multi-machine setups coming soon.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── Screenshot Showcase Section ─── -->
  <section class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="views-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="VIEW MODES"
        title="Seven ways to see your GPUs"
        subtitle="Switch between views with a single keystroke. Each mode is purpose-built for a different monitoring task."
      />

      <div class="mt-16 grid grid-cols-1 gap-10 md:grid-cols-2">
        <Screenshot
          src="/screenshots/grid-4gpu.png"
          alt="gpulse Grid view with 4 NVIDIA GPUs showing VRAM usage bars, GPU utilization, temperature, power draw, and a process table with python training workloads"
          caption="Grid View — All GPUs at a glance with per-process attribution"
          glow={false}
        />
        <Screenshot
          src="/screenshots/predict-leak-detected.png"
          alt="gpulse Predict mode showing a risk overview table with GPU 0 flagged as HIGH risk, linear trend detector output with R-squared 0.98, growth rate, and ETA to OOM"
          caption="Predict Mode — Memory leak detected, ETA to OOM calculated"
          glow={false}
        />
        <Screenshot
          src="/screenshots/detail-gpu0-critical.png"
          alt="gpulse Detail view showing GPU 0 NVIDIA RTX 4090 in critical state with 17.5 of 24 GB VRAM used, full process table with CPU and GPU utilization columns"
          caption="Detail View — Full metrics for a single GPU"
          glow={false}
        />
        <Screenshot
          src="/screenshots/compare-4gpu.png"
          alt="gpulse Compare view showing 4 GPUs in a 2x2 grid with memory bars, utilization percentages, temperature and power side by side"
          caption="Compare View — Side-by-side across all GPUs"
          glow={false}
        />
      </div>
    </div>
  </section>

  <!-- ─── How It Works Section ─── -->
  <section class="py-24 md:py-32 relative overflow-hidden" aria-labelledby="get-started-heading">
    <!-- Subtle gradient bg -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-cyan/[0.02] to-transparent" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="GET STARTED"
        title="Up and running in 30 seconds"
        subtitle="No configuration files. No dependencies. One command to install, one command to launch."
      />

      <!-- Steps with connecting line -->
      <div class="mt-16 relative">
        <!-- Connecting line (hidden on mobile, visible on md+) -->
        <div class="hidden md:block absolute top-[60px] left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-cyan/0 via-cyan/30 to-cyan/0" aria-hidden="true"></div>

        <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
          <!-- Step 1 -->
          <div class="relative flex flex-col items-center text-center">
            <!-- Glowing number badge -->
            <div class="relative mb-6">
              <div class="flex items-center justify-center w-[120px] h-[120px] rounded-2xl border border-cyan/20 bg-surface">
                <span class="text-5xl font-bold font-mono text-cyan">1</span>
              </div>
              <!-- Glow -->
              <div class="absolute inset-0 rounded-2xl bg-cyan/5 blur-xl -z-10" aria-hidden="true"></div>
            </div>
            <h3 class="text-xl font-bold mb-4">Install</h3>
            <p class="text-muted text-sm mb-6">One command via Homebrew. No dependencies.</p>
            <Terminal
              title="Terminal"
              command="brew install kkirubakaran/gpulse/gpulse"
              class="w-full"
            />
          </div>

          <!-- Step 2 -->
          <div class="relative flex flex-col items-center text-center">
            <div class="relative mb-6">
              <div class="flex items-center justify-center w-[120px] h-[120px] rounded-2xl border border-cyan/20 bg-surface">
                <span class="text-5xl font-bold font-mono text-cyan">2</span>
              </div>
              <div class="absolute inset-0 rounded-2xl bg-cyan/5 blur-xl -z-10" aria-hidden="true"></div>
            </div>
            <h3 class="text-xl font-bold mb-4">Launch</h3>
            <p class="text-muted text-sm mb-6">Start the dashboard. That's it.</p>
            <Terminal
              title="Terminal"
              command="gpulse dashboard"
              class="w-full"
            />
          </div>

          <!-- Step 3 -->
          <div class="relative flex flex-col items-center text-center">
            <div class="relative mb-6">
              <div class="flex items-center justify-center w-[120px] h-[120px] rounded-2xl border border-cyan/20 bg-surface">
                <span class="text-5xl font-bold font-mono text-cyan">3</span>
              </div>
              <div class="absolute inset-0 rounded-2xl bg-cyan/5 blur-xl -z-10" aria-hidden="true"></div>
            </div>
            <h3 class="text-xl font-bold mb-4">Monitor</h3>
            <p class="text-muted text-sm mb-6">Navigate views with single keystrokes.</p>
            <!-- Keybindings grid -->
            <div class="w-full rounded-xl border border-border bg-dark/80 p-5">
              <div class="grid grid-cols-2 gap-3 text-left">
                <div class="flex items-center gap-2">
                  <kbd class="inline-flex items-center justify-center w-7 h-7 rounded border border-border bg-surface font-mono text-xs text-cyan">d</kbd>
                  <span class="text-muted text-xs">Detail</span>
                </div>
                <div class="flex items-center gap-2">
                  <kbd class="inline-flex items-center justify-center w-7 h-7 rounded border border-border bg-surface font-mono text-xs text-cyan">P</kbd>
                  <span class="text-muted text-xs">Predict</span>
                </div>
                <div class="flex items-center gap-2">
                  <kbd class="inline-flex items-center justify-center w-7 h-7 rounded border border-border bg-surface font-mono text-xs text-cyan">c</kbd>
                  <span class="text-muted text-xs">Compare</span>
                </div>
                <div class="flex items-center gap-2">
                  <kbd class="inline-flex items-center justify-center w-7 h-7 rounded border border-border bg-surface font-mono text-xs text-cyan">t</kbd>
                  <span class="text-muted text-xs">Theme</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pricing Section ─── -->
  <section id="pricing" class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="pricing-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="PRICING"
        title="Free for individuals. Pro for teams."
        subtitle="Download and start monitoring in seconds. No account required, no credit card needed."
      />

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Free Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <h3 class="text-xl font-bold">Free</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$0</span>
              <span class="text-muted text-sm">forever</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Local GPU monitoring
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                All vendors (NVIDIA, Apple, AMD, Intel)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                15 color themes
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                7 view modes
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                OOM prediction & leak detection
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Prometheus endpoint
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="#download" className="w-full" client:load>
                Download Now
              </Button>
            </div>
          </div>
        </Card>

        <!-- Pro Tier -->
        <Card highlighted={true} client:load>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-3">
              <h3 class="text-xl font-bold">Pro</h3>
              <Badge variant="cyan" client:load>Coming Soon</Badge>
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$29</span>
              <span class="text-muted text-sm">/month</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Free
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Fleet monitoring (SSH, up to 20 machines)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Email, Slack & Discord alerts
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Web dashboard
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Multi-machine support
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Priority support
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="#waitlist" className="w-full" client:load>
                Join Waitlist
              </Button>
            </div>
          </div>
        </Card>

        <!-- Enterprise Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-3">
              <h3 class="text-xl font-bold">Enterprise</h3>
              <Badge variant="cyan" client:load>Coming Soon</Badge>
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">Custom</span>
            </div>
            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Pro
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Cloud API integration (AWS/Azure/GCP)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Agent-based fleet monitoring
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                RBAC & SSO
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                GPU scheduling & orchestration
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Audit logs & SLA
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="secondary" size="lg" href="mailto:info@gpulse.ai" className="w-full" client:load>
                Contact Us
              </Button>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- ─── FAQ Section ─── -->
  <section class="py-24 md:py-32" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="FAQ"
        title="Frequently asked questions"
      />

      <div class="mt-16 space-y-4">
        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            What GPUs are supported?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            gpulse supports NVIDIA (via NVML), Apple Silicon (via Metal/IOKit), AMD (via ROCm), and Intel (via Level Zero). All major GPU vendors are supported out of the box.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold transition-colors hover:text-cyan [&::-webkit-details-marker]:hidden">
            Does gpulse work on Linux?
            <svg class="w-5 h-5 text-muted transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
          </summary>
          <div class="px-6 pb-5 text-muted leading-relaxed">
            gpulse currently supports macOS (both Apple Silicon and Intel). Linux support is coming soon in a future release.
          </div>
        </details>

        <details class="group rounded-xl border border-border bg-surface transition-colors open:border-cyan/30">
