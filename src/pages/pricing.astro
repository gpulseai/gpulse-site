---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { Badge } from '../components/ui/Badge';
import { Button } from '../components/ui/Button';
import { Card } from '../components/ui/Card';
---

<BaseLayout
  title="Pricing — gpulse"
  description="Simple, transparent pricing for GPU monitoring. Free forever for local monitoring. Pro for teams. Enterprise for large-scale fleet management."
>
  <!-- AEO: Clean pricing summary for AI engines -->
  <div class="sr-only" aria-hidden="false">
    <p>gpulse pricing: Free tier ($0 forever) includes local GPU monitoring, OOM prediction, leak detection, 15 themes, 7 view modes, Prometheus endpoint, all GPU vendors (NVIDIA, Apple Silicon, AMD, Intel), no telemetry. Pro tier ($29/month) adds fleet SSH monitoring up to 20 machines, bastion host support, email/Slack/Discord alerts, webhook integrations, web dashboard, multi-machine comparison, priority support, 14-day free trial. Enterprise tier (custom pricing) adds cloud API integration (AWS/Azure/GCP), agent-based fleet monitoring (50+ nodes), RBAC and SSO, GPU scheduling, audit logs, PagerDuty/OpsGenie integration, SLA, dedicated support engineer.</p>
  </div>

  <!-- Hero -->
  <section
    class="relative flex flex-col items-center justify-center px-4 pt-36 pb-16"
    aria-labelledby="pricing-heading"
  >
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      <div class="absolute left-1/2 top-0 -translate-x-1/2 -translate-y-1/4 h-[800px] w-[800px] rounded-full bg-cyan/[0.04] blur-[120px]"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center text-center">
      <h1
        id="pricing-heading"
        class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]"
      >
        Pricing
      </h1>
      <p class="text-lg md:text-xl text-muted mt-6 max-w-2xl leading-relaxed">
        Simple, transparent pricing. Free forever for local monitoring.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-24 md:py-32" aria-label="Pricing tiers">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">

        <!-- Free Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <h3 class="text-xl font-bold">Free</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$0</span>
              <span class="text-muted text-sm">forever</span>
            </div>
            <p class="text-sm text-muted mt-3">Everything you need for local GPU monitoring.</p>

            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Local GPU monitoring
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Apple Silicon, NVIDIA, AMD, Intel
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                15 color themes (Monokai, Dracula, Nord, etc.)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                7 view modes (Grid, Detail, List, Predict, Compare, Topology, Fleet)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                OOM prediction &amp; leak detection
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Per-process GPU attribution (%UTL, %CPU, %MEM)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Prometheus /metrics endpoint
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                OpenTelemetry export
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                SQLite data persistence
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Keyboard-driven interface
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Colorblind-safe themes
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                No telemetry, no data collection
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="/download" className="w-full" client:load>
                Download Now
              </Button>
            </div>
          </div>
        </Card>

        <!-- Pro Tier -->
        <Card highlighted={true} client:load>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-3">
              <h3 class="text-xl font-bold">Pro</h3>
              <Badge variant="cyan" client:load>Coming Soon</Badge>
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">$29</span>
              <span class="text-muted text-sm">/month</span>
            </div>
            <p class="text-sm text-muted mt-3">For teams monitoring multiple machines.</p>

            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Free
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Fleet SSH monitoring (up to 20 machines)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Bastion/jump host support
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Email alerts
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Slack &amp; Discord notifications
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Webhook integrations
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Web dashboard <span class="text-xs text-muted/60">(coming)</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Multi-machine comparison
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Priority email support
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                14-day free trial
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="primary" size="lg" href="mailto:info@gpulse.ai?subject=gpulse%20Pro%20Waitlist" className="w-full" client:load>
                Join Waitlist
              </Button>
            </div>
          </div>
        </Card>

        <!-- Enterprise Tier -->
        <Card client:load>
          <div class="flex flex-col h-full">
            <div class="flex items-center gap-3">
              <h3 class="text-xl font-bold">Enterprise</h3>
              <Badge variant="cyan" client:load>Coming Soon</Badge>
            </div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold">Custom</span>
            </div>
            <p class="text-sm text-muted mt-3">For large-scale GPU fleet management.</p>

            <ul class="mt-8 space-y-4 flex-1" role="list">
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Pro
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Cloud API integration (AWS EC2, Azure VMs, GCP Compute)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Agent-based fleet monitoring (50+ GPU nodes)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                RBAC &amp; SSO (SAML, OIDC)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                GPU scheduling &amp; orchestration
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Audit logs
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Custom alert policies &amp; escalation
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                PagerDuty/OpsGenie integration
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                SLA (99.9% monitoring uptime)
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Dedicated support engineer
              </li>
              <li class="flex items-start gap-3 text-sm text-muted">
                <svg class="w-5 h-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Custom integrations
              </li>
            </ul>
            <div class="mt-8">
              <Button variant="secondary" size="lg" href="mailto:info@gpulse.ai?subject=gpulse%20Enterprise%20Inquiry" className="w-full" client:load>
                Contact Us
              </Button>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Detailed Comparison Table -->
  <section class="py-24 md:py-32 bg-surface section-gradient-top" aria-labelledby="comparison-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="COMPARE"
        title="What's in each tier?"
        subtitle="Every tier includes full local GPU monitoring. Pro adds fleet visibility. Enterprise adds cloud-scale automation."
      />

      <div class="mt-16 overflow-x-auto -mx-4 px-4">
        <table class="w-full min-w-[640px] border-collapse" role="grid">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-4 pr-4 text-sm font-semibold text-muted w-[40%]">Feature</th>
              <th class="text-center py-4 px-4 text-sm font-semibold w-[20%]">Free</th>
              <th class="text-center py-4 px-4 text-sm font-semibold w-[20%]">
                <span class="inline-flex items-center gap-2">Pro <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-yellow/10 border border-yellow/20 text-yellow">PRO</span></span>
              </th>
              <th class="text-center py-4 px-4 text-sm font-semibold w-[20%]">
                <span class="inline-flex items-center gap-2">Enterprise <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-purple/10 border border-purple/20 text-purple">ENT</span></span>
              </th>
            </tr>
          </thead>
          <tbody class="text-sm">
            <!-- Core Features group -->
            <tr class="border-b border-border/50">
              <td colspan="4" class="pt-6 pb-2 text-xs font-mono uppercase tracking-wider text-cyan">Core Monitoring</td>
            </tr>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 pr-4 text-muted">Local GPU monitoring</td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
            </tr>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 pr-4 text-muted">Apple Silicon + NVIDIA + AMD + Intel</td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
            </tr>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 pr-4 text-muted">15 themes, 7 view modes</td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
            </tr>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 pr-4 text-muted">OOM prediction &amp; leak detection</td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
              <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-cyan mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg></td>
            </tr>
            <tr class="border-b border-border/30 hover:bg-surface-elevated/50 transition-colors">
              <td class="py-3 pr-4 text-muted">Per-process GPU attribution</td>
