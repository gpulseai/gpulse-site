---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service — gpulse"
  description="Terms of Service for the gpulse GPU monitoring tool and gpulse.ai website."
>
  <section class="px-4 pt-32 pb-24">
    <div class="mx-auto max-w-3xl">

      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <a href="/" class="text-sm text-muted transition-colors hover:text-cyan">
          &larr; Back to Home
        </a>
      </nav>

      <!-- Page header -->
      <header class="mb-16">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">Terms of Service</h1>
        <p class="mt-4 text-muted text-lg">
          Effective Date: <time datetime="2026-03-21">March 21, 2026</time>
        </p>
      </header>

      <!-- Content -->
      <div class="space-y-12 text-muted leading-relaxed">

        <!-- 1. Acceptance of Terms -->
        <section>
          <h2 class="text-xl font-semibold text-white mb-4">1. Acceptance of Terms</h2>
          <p>
            By downloading, installing, copying, or otherwise using the gpulse software ("Software") or accessing the gpulse.ai website ("Website"), you agree to be bound by these Terms of Service ("Terms"). If you do not agree to these Terms, do not download, install, or use the Software, and do not access the Website.
