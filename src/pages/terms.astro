            <li><strong class="text-white">Sales:</strong> <a href="mailto:sales@gpulse.ai" class="text-cyan hover:underline">sales@gpulse.ai</a></li>
            <li><strong class="text-white">General:</strong> <a href="mailto:karthik@gpulse.ai" class="text-cyan hover:underline">karthik@gpulse.ai</a></li>
          </ul>
