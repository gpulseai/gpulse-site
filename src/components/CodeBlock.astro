---
interface Props {
  code: string;
  language?: string;
  class?: string;
}

const { code, language = 'bash', class: className } = Astro.props;
const elementId = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={[
    'relative rounded-xl border border-border overflow-hidden bg-[#0d0d0d]',
    className,
  ]}
>
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-2 border-b border-border bg-surface">
    <span class="text-xs text-muted font-mono">{language}</span>
    <button
      type="button"
      class="flex items-center justify-center h-6 w-6 rounded text-muted transition-colors hover:text-white hover:bg-dark/50"
      aria-label="Copy code"
      data-copy-code={elementId}
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
      </svg>
    </button>
  </div>

  <!-- Code body -->
  <pre class="px-5 py-4 overflow-x-auto"><code id={elementId} class="font-mono text-sm text-muted leading-relaxed">{code}</code></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-code]').forEach((button) => {
    button.addEventListener('click', async () => {
      const targetId = button.getAttribute('data-copy-code');
      if (!targetId) return;

      const codeEl = document.getElementById(targetId);
      if (!codeEl) return;

      const text = codeEl.textContent?.trim() || '';

      try {
        await navigator.clipboard.writeText(text);
        button.setAttribute('aria-label', 'Copied!');
        button.classList.add('text-cyan');

        setTimeout(() => {
          button.classList.remove('text-cyan');
          button.setAttribute('aria-label', 'Copy code');
        }, 2000);
      } catch {
        const range = document.createRange();
        range.selectNodeContents(codeEl);
        const selection = window.getSelection();
        selection?.removeAllRanges();
        selection?.addRange(range);
      }
    });
  });
</script>
