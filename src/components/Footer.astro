---
const productLinks = [
  { href: '/download', label: 'Download' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
  { href: '/changelog', label: 'Changelog' },
];

const resourceLinks = [
  { href: '/docs', label: 'Documentation' },
  { href: '/docs/getting-started', label: 'Getting Started' },
  { href: '/docs/keyboard', label: 'Keyboard Shortcuts' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://discord.gg/EpCuZEJd', label: 'Discord Community' },
];

const legalLinks = [
  { href: '/terms', label: 'Terms of Service' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: 'mailto:info@gpulse.ai', label: 'Contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-border" role="contentinfo">
  <!-- Gradient top border glow -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/40 to-transparent" aria-hidden="true"></div>

  <div class="mx-auto max-w-[1400px] px-6 py-16">
    <!-- Top row: Logo + tagline + link columns -->
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-12">
      <!-- Brand column -->
      <div class="max-w-sm">
        <a href="/" class="text-2xl font-bold font-mono text-cyan" aria-label="gpulse home">
          gpulse
        </a>
        <p class="mt-3 text-sm text-muted leading-relaxed">
          Real-time GPU monitoring with predictive OOM detection. One tool for Apple&nbsp;Silicon, NVIDIA, AMD, and Intel.
        </p>
        <!-- Built with Rust badge -->
        <div class="mt-4 flex items-center gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-surface border border-border px-3 py-1 text-xs text-muted">
            <svg class="w-3 h-3 text-[#dea584]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.834 8.101a13.912 13.912 0 0 1-13.643 11.72 10.105 10.105 0 0 1-1.994-.12 6.111 6.111 0 0 1-5.082-5.761 5.934 5.934 0 0 1 11.867-.084c.025.983-.401 1.846-1.277 1.871-.936 0-1.374-.668-1.374-1.567v-2.5a1.531 1.531 0 0 0-1.52-1.533H8.715a3.648 3.648 0 1 0 2.695 6.08l.073-.084.073.084a2.413 2.413 0 0 0 2.437.918 2.882 2.882 0 0 0 2.127-2.752v-.07a7.801 7.801 0 0 0-7.592-8.001 7.801 7.801 0 0 0-8.009 7.593 8.066 8.066 0 0 0 6.668 8.083 8.104 8.104 0 0 0 .899.06 13.912 13.912 0 0 0 13.868-13.832z"/>
            </svg>
            Built with Rust
          </span>
        </div>
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3">
        <!-- Product -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Product</h3>
          <ul class="mt-4 space-y-3" role="list">
            {productLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted transition-colors duration-200 hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Resources</h3>
          <ul class="mt-4 space-y-3" role="list">
            {resourceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted transition-colors duration-200 hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Legal</h3>
          <ul class="mt-4 space-y-3" role="list">
            {legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted transition-colors duration-200 hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Social proof line -->
    <div class="mt-12 text-center">
      <p class="text-sm text-muted/60 italic">
        Monitoring GPUs on Mac Studio, NVIDIA DGX, and everything in between.
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 flex flex-col items-center justify-between gap-6 border-t border-border pt-8 sm:flex-row">
      <p class="text-sm text-muted">
        &copy; {currentYear} gpulse. All rights reserved.
      </p>

      <!-- Social icons -->
      <div class="flex items-center gap-5">
        <!-- GitHub -->
        <a
          href="https://github.com/gpulseai/gpulse"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted transition-colors duration-200 hover:text-white"
          aria-label="gpulse on GitHub"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            />
          </svg>
        </a>

        <!-- Twitter / X -->
        <a
          href="https://x.com/datakarthik"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted transition-colors duration-200 hover:text-white"
          aria-label="gpulse on X (Twitter)"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>

        <!-- Discord -->
        <a
          href="https://discord.gg/EpCuZEJd"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted transition-colors duration-200 hover:text-white"
          aria-label="gpulse on Discord"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
          </svg>
        </a>

        <!-- Email -->
        <a
          href="mailto:info@gpulse.ai"
          class="text-muted transition-colors duration-200 hover:text-white"
          aria-label="Email gpulse"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
